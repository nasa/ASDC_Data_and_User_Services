       program s7  
c 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
c   name - s7                                 module -
c   language - ftn v                          type - main program 
c   version - 3.0         date - 07/27/89     programmer -
c                                               flug, b.t. - prc
c   version - 4.0         date - 12/14/92     programmer -
c                                               nolan, s.k. - lesc
c 
c 
c   purpose - 
c      to read and dump selected records from the monthly 
c      medium/wide fov data file (S-7)
c 
c   input files - 
c      unit7 - binary monthly medium-wide data file;
c              contains a header, scale factors, offsets, 
c              and medium-wide data ( all packed )
c
c   input parameters-
c
c     ( The following parameters are currently read in as
C       character strings using a unix system call. The integers
c       are read using these strings as internal files.  A
c       namelist could be used to replace this code.  See
c       comments within code.)
c
c     s7nam   - name of S7 file (1-7 characters)
c     ibegrc  - starting position of record to dump 
c     iendrc  - ending position of record to dump 
c     idday   - day for which the records are to be dumped
c               ( = 0 if records for entire month )
c 
c   output files -
c      fort.9 - formatted print of requested S-7 records. 
c 
c   key local parameters -
c     cff     - form feed character for printer
c     dbytes  - number of bytes contained in daily record count record (=90)
c     dflag   - logical flag set false if current record 
c               is greater than requested record
c     hbytes  - number of bytes contained in header record (=30)
c     iarray  - daily record count array
c     ibegrc  - starting position of record to dump 
c     iblock  - block counter 
c     icnt    - counts number of records per block
c     idatlbl - file containing record index, no. of characters in the
c               labels, labels, and no. of lines of data for each label 
c     idata   - unpacked physical S-7 header array
c     iday    - day of the month
c     idday   - day for which the records are to be dumped
c     iendrc  - ending position of record to dump 
c     iertype - type of I/O error
c     index   - array dimensioned 36 containing the record index for
c               each label
c     ipcn    - product code
c     ibrec   - record counter for records in 20 record block
c     irc     - byte address record counter
c     irec    - record counter for each day of records
c     ios     - variable used for i/o error trapping
c     is7hd   - erbe logical header for S-7 
c     is7num  - number of characters in name of file containing S-7 data
c     is7out  - unit number for S-7 
c     iunout  - unit number associated with standard output 
c     label   - array dimensioned 36 containing the output labels 
c     mnwd60  - the number of packed words for a medium-wide data 
c               record (=45)
c     mrecfr  - the number of medium-wide data records per data block (=20) 
c     n       - counts the number of lines of information printed on
c               a page
c     nwds7   - number of words in a medium-wide data record (=75)
c     parmvl  - character value representing passed value 
c     prodin  - input product name
c     rbytes  - number of bytes per medium-wide data record (=180)
c     s7nam   - name of file containing S-7 data
c     wumwd   - temporary array to hold 1st record of 20 record block
c     xdate   - array(6) containing current calendar date 
c 
c   commons used -
c                    *** / charcm / *** 
c 
c 
c     /charcm/- a common block of character information for output. 
c               see erbe utilities user's guide 
c      iscnam(1) - 6 character name of spacecraft 1 (='noaa f') 
c      iscnam(2) - 6 character name of spacecraft 2 (='erbs') 
c      iscnam(3) - 6 character name of spacecraft 3 (='noaa g') 
c 
c 
c                         *** / global / ***
c 
c 
c     /global/- a common block of parameters needed for utilities 
c               see erbe utilities user's guide.
c      isubno - subsystem number set to 5.
c      iversn - version number or release of the subsystem.  the first
c               version is 1 and each subsequent version is incremented 
c               by 1. 
c 
c 
c                         *** / scldat / ***
c 
c 
c     /scldat/ - a common block of parameters needed to apply 
c                scale factors and offsets to the unpacked, 
c                integer monthly medium-wide data 
c      ierror  - array(2) of integer default values:  
c                     (1) = ( 2**31 ) - 1 
c                     (2) = ( 2**15 ) - 1 
c      mfwa    - array(4) containing starting locations in the
c                xmwdt array for values to be packed at 32 bits,
c                16 bits, 8 bits, or 4 bits per word
c      mnwd    - array(4) for the number of values packed at
c                32 bits, 16 bits, 8 bits, or 4 bits per word 
c      iumwd   - array(75) containing a single, unpacked S-7 record 
c      xerror  - real default value ( = (2**15) - 1 ) 
c      xmwdt   - array(75,10) containing up to 10 records 
c                from the S-7 
c      xmwoff  - array(75) of offsets to be applied to integer
c                medium-wide data 
c      xmwsf   - array(75) of scale factors to be applied to
c                integer medium-wide data 
c 
c 
c 
c   subroutines called -
c     dmps7   - print out up to 10 records from the S-7 
c     g16hedn - retrieve erbe logical header 
c     julcal  - convert a given julian date to the corresponding
c               calendar date (g.e.8.5.2) 
c     getarg  - get parameter from execution control statement  
c     ppspec  - print product specifications (g.5.20)
c     prphed  - write an external output form physical header record 
c     sysmsg  - handle subsystem error message processing  
c     sfoff   - apply scale factors and offsets to monthly m/w data 
c 
c   comments -
c
c     binary S7 file is opened as an unformatted direct access file
c     with record length, recl=1.  16 bit data is read into integer*2
c     arrays and 32 bit data is read into integer*4 arrays (which
c     eliminates the need for unpacking subroutines).  the direct
c     access reads require a byte address to access data. 
c 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
      common / global / isubno, iversn
      common / charcm / iscnam(3)
      character iscnam *6
      character*1 cff
c 
      common / scldat / ierror(2),  mfwa(4), mnwd(4), 
     1                  iumwd(75),  xerror,  xmwdt(75,10),
     2                  xmwoff(75), xmwsf(75) 
c 
      character*5 prodin
      character*7 parmvl, s7nam
      character*32 label(36)
      logical dflag
      integer*4 buffer1(15), index(36)
      integer*4 dbytes, hbytes, rbytes
      integer*2 idata(15),buffer2(60),iarray(31)
      dimension is7hd( 9) 
c     dimension xdate( 6) 
c     dimension wumwd( 75 )
c 
      data  iunout, idatlbl,is7out /  9, 12, 7 /
      data mfwa / 1, 16, 0, 0 / 
      data mnwd / 15, 60, 0, 0 /
      data mnwd60, mrecfr, nwds7 / 45, 20, 75 / 
      data prodin / 'S-7' / 
      data xerror / 32767. /
      data index /1,2,3,4,6,8,10,12,14,16,18,20,21,22,23,
     1            27,31,35,39,43,47,51,55,56,57,58,59,60,
     2            61,62,63,67,71,73,74,75/
      data label(1) /'Julian date                     '/
      data label(2) /'Julian time                     '/
      data label(3) /'Earth - Sun distance            '/
      data label(4) /'s/c position, x                 '/
      data label(5) /'s/c position, y                 '/
      data label(6) /'s/c position, z                 '/
      data label(7) /'s/c velocity (xdot)             '/
      data label(8) /'s/c velocity (ydot)             '/
      data label(9) /'s/c velocity (zdot)             '/
      data label(10) /'s/c nadir position, colatitude  '/
      data label(11) /'s/c nadir position, longitude   '/
      data label(12) /'sun position, colatitude        '/
      data label(13) /'sun position, longitude         '/
      data label(14) /'orbit number key                '/
      data label(15) /'wfov, radiometric, total        '/
      data label(16) /'wfov, radiometric, sw           '/
      data label(17) /'mfov, radiometric, total        '/
      data label(18) /'mfov, radiometric, sw           '/
      data label(19) /'wfov, unfiltered, sw            '/
      data label(20) /'wfov, unfiltered, lw            '/
      data label(21) /'mfov, unfiltered, sw            '/
      data label(22) /'mfov, unfiltered, lw            '/
      data label(23) /'wfov, toa est., nf, sw          '/
      data label(24) /'wfov, toa est., nf, lw          '/
      data label(25) /'mfov, toa est., nf, sw          '/
      data label(26) /'mfov, toa est., nf, lw          '/
      data label(27) /'wfov, toa est., sf, sw          '/
      data label(28) /'wfov, toa est., sf, lw          '/
      data label(29) /'mfov, toa est., sf, sw          '/
      data label(30) /'mfov, toa est., sf, lw          '/
      data label(31) /'nonscanner, fov, colatitude     '/
      data label(32) /'nonscanner, fov, longitude      '/
      data label(33) /'nonscanner, op. mode, flag word '/
      data label(34) /'flag, nonscanner, toa est.      '/
      data label(35) /'orbit number scale factor       '/
      data label(36) /'spare                           '/
c
      dbytes = 90
      hbytes = 30
      rbytes = 180
c 
c *** calculate ierror values 
c 
      cff = char(12)
      ierror( 1) = 2**31 - 1
      ierror( 2) = 2**15 - 1
c 
c *** initialize system utilities.
c 
      isubno = 5
      iversn = 1
c 
c *** open  is7out (S-7). 
c 
      call getarg( 1,s7nam)
      open( is7out,file=s7nam, iostat = ios, form='unformatted',
     * access='direct',recl=1)
      if (ios.ne.0) then
  	iertyp = 1
       call sysmsg(ios, iertyp, s7nam)
       end if
       irc =1
c 
c *** read physical header record. 
c 
      call g16hedn
     i           ( is7out,
     o             is7hd, idata, irc, s7nam) 
c 
c 
c ***  print out tape specifications
c 
      ipcn = 9
      call ppspec 
     i           ( iunout, is7hd, ipcn, prodin, s7nam) 
c 
c ***  print out contents of physical header
c 
      call prphed 
     i           ( iunout, idata ) 
c 
c *** print out labeling information
c 
cC    write(iunout,1000)
      write ( iunout,'(a1)')cff
      write(iunout,1090)
      write(iunout,2000)
      write(iunout,2010) ( index(j), label(j), j = 1, 36 )
c 
c *** get start and end records,passed as parameters
c 
      call getarg( 2, parmvl )
      read( parmvl, '(i4)', iostat = ios) ibegrc
      if (ios.ne.0) then
 	 iertyp = 2
 	 call sysmsg(ios, iertyp, 'internal')
      end if
c 
      call getarg( 3, parmvl )
      read( parmvl, '(i4)', iostat = ios) iendrc
      if (ios.ne.0) then
         iertyp = 2
         call sysmsg(ios, iertyp, 'internal')
      end if
c 
c ***  terminate if header only is being dumped (ibegrc = 0)
c 
      if ( ibegrc .eq. 0 ) then 
c 
           go to 900
c 
      end if
c 
c *** get dumping day 
c 
      call getarg( 4, parmvl )
      read( parmvl, '(i4)', iostat = ios) idday
      if (ios.ne.0) then
         iertyp = 2
         call sysmsg(ios, iertyp, 'internal')
      end if 
c
c *** Read daily record count array
c 
      read(is7out, iostat=ios,end=900,rec=irc) iarray
      irc = irc + dbytes
c 
c *** read scale factors
c 
      read(is7out, iostat=ios,end=900,rec=irc) buffer1,buffer2
      if ( ios .ne. 0 ) then
           iertyp = 2 
           call sysmsg
     i                 ( ios, 
     o                   iertyp, s7nam)
c          *******************
c          *   fatal error   *
c          *******************
c 
      end if
c 
c 
c *** convert integer scale factors to real scale factors 
c 
      do 50 i = 1,15 
         xmwsf( i) = float( buffer1( i) )
   50 continue
      do 51 i = 1,60 
         xmwsf( i+15) = float( buffer2( i) )
   51 continue
      irc= irc+rbytes
c 
c *** read offsets
c 
      read(is7out, iostat=ios,end=900,rec=irc) buffer1,buffer2
      if ( ios .ne. 0 ) then
         iertyp = 2 
           call sysmsg
     i                 ( ios, 
     o                   iertyp, s7nam)
c          *******************
c          *   fatal error   *
c          *******************
c 
      end if
c 
c 
c *** convert integer offsets to real offsets 
c 
      do 75 i = 1,15 
         xmwoff( i) = float( buffer1( i) )
   75 continue
      do 76 i = 1,60 
         xmwoff( i+15) = float( buffer2( i) )
   76 continue
      irc= irc+rbytes
c 
c *** print out scale factors and offsets 
c 
      n = 0 
c 
      do 100 i = 1, nwds7 
c 
         n = n + 1
c 
         if( ( i .eq. 1 ) .or. ( n .eq. 47 ) ) then 
CC           write( iunout, 1000) 
             write ( iunout,'(a1)')cff
             write( iunout, 1070) 
             n = 6
         end if 
c 
         write( iunout, 1080) i, xmwsf(i), i, xmwoff(i) 
c 
  100 continue
c 
c *** initialize record counters
c 
      dflag = .true.
      iblock = 0
      irec = 0
      k = 0 
      iday = 0
      icnt = 0
c 
  200 continue
c 
      if ( idday .eq. 0 ) then
       iday = iday + 1
      else
        iday = idday
      endif
c
      if (iarray(iday) .eq. 0) then
          write(iunout,1200) iday
          go to 400
      endif
c 
      isum = 0
      if ( iday .ne. 1) then
          do 210, i= 1,iday-1
             isum = isum + (iarray(i)*180)
  210     continue
      endif
c
C *** calculate byte address of beginning record
c
      irc = hbytes + dbytes + (2*rbytes) + isum +
     1      ((ibegrc-1) * rbytes) + 1
      irec = ibegrc - 1
c 
c *** process records 
c
  350 continue 
c 
      k = k + 1
      irec = irec +1
c 
      read(is7out, iostat=ios,end=900,rec=irc) buffer1,buffer2
      if (ios.ne.0) then
         iertyp = 2
         call sysmsg(ios, iertyp, s7nam)
      end if
      irc= irc+rbytes
      do 360, i = 1,15
           iumwd(i) = buffer1(i)
 360  continue
      do 361, i = 1,60
           iumwd(i+15) = buffer2(i)
 361  continue
c 
c *** apply scale factors and offsets 
c 
      call sfoff
     i          ( k ) 
c 
      if( k .lt. 10 .and. irec .lt. iendrc )then
            goto 350 
      endif
      if( ( k .eq. 10 ) .or. ( irec .eq. iendrc ) ) then
c 
c *** print records  
c
          call dmps7
     i                ( k, xmwdt, irec, iunout, label, iday ) 
c 
          if ( irec .lt. iendrc ) then 
c 
                k = 0 
                goto 350
          endif
      endif
 400  continue
      if (( idday .eq. 0 ) .and. ( iday .lt. 31)) then
         k = 0
        goto 200
      endif
c
c 
  900 continue
c 
c     iterm = 0 
c 
c *** format statements 
c 
 1000 format (1h1)
 1005 format ( // ) 
 1020 format (//1x, 13hrecord num = , 10x, i4, 9(8x,i4) ) 
 1070 format ( //21x, 13hscale factors, 39x, 14hoffsets record, / ) 
 1080 format ( 1x, 7hxmwsf (, i2, 4h) = , f20.9, 20x, 7hxmwoff(, i2, 
     1         4h) = , f20.9 )
 1090 format (/1x, 19hrecord information:, //)
 1200 format (//1x, 'Day - ',i4,' contains no data')
 2000 format ( 7x, 5hindex, 7x, 7hcontent, / )
 2010 format ( 8x, i4, 7x, a32 )
 5000 format ( //5x, 40hthere are no more files on this S-7 file )
 5010 format ( //5x, 41hthere are no more records on current file ) 
c 
      end 
c
       subroutine datchr(wjd,fjd,ireslt)
c   **********************************************************
c 
c   name - datchr                             module -
c   language - ftn v                          type - subroutine 
c   version - 1.0         date - 12/18/92     programmer -
c                                               nolan, s.k. -lesc
c 
c   
c   purpose - to create a character string  containing the
c             time span of a given month based on a julian
c             date.
c
c   input parameters  - 
c      wjd     - whole part of julian date 
c      fjd     - fractional part of julian date 
c
c   output parameters  - 
c      ireslt  - character string containing the time
c                span of month corresponding to julian date
c
c   key local parameters  -
c      iyear, imon  - integer forms of the date calculated by julcal
c      lday  - last day of the month
c   **********************************************************
       dimension  xdate(6)
       character*30 ireslt
       ireslt= '  /0 /01 0000 -   /0 /   2359 ' 
       call julcal(wjd,fjd,0,xdate)
       iyear = int(xdate(1))
       imon = int(xdate(2))
       go to ( 10,30,10,20,10,20,10,10,20,10,20,10), imon
       go to 50
 10    lday = 31
       go to 40
 20    lday = 30
       go to 40
 30    if(mod(iyear,4) .eq. 0 ) then
         lday = 29
       else
         lday = 28
       endif
 40    continue
       write(ireslt(1:2),'(i2)')iyear
       write(ireslt(17:18),'(i2)')iyear
       if (imon .lt. 10)then
            write(ireslt(5:5),'(i1)')imon
            write(ireslt(21:21),'(i1)')imon
       else
            write(ireslt(4:5),'(i2)')imon
            write(ireslt(20:21),'(i2)')imon
       endif
       write(ireslt(23:24),'(i2)')lday
 50    continue
       return
       end
c
c 
      subroutine dmps7
     i                  ( k, xmwdt, irec, iunout, label, iday ) 
c 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
c   name - dmps7                              module -
c   language - ftn v                          type - subroutine 
c   version - 3.0         date - 07/26/89     programmer -
c                                               flug, b.t. - prc
c 
c 
c   purpose - 
c     print out up to 10 recs from the monthly medium-wide
c     data tape (s-7) 
c 
c   input parameters -
c      idatlbl - file containing record index, no. of characters in the 
c                labels, labels and no. of lines of data for each label 
c      iday    - current day of the month 
c      irec    - record counter 
c      iunout  - unit number associated with standard output
c      k       - number of records to be dumped 
c      xmwdt   - array containing up to 10 records from the s-7 
c 
c   key local parameters -
c      index   - value of the record index for current label
c      istrln  - number of characters in the label
c      label   - current output label 
c      lbls    - counter for the labels 
c      n       - counts the number of lines of information printed on 
c                a page 
c      nline   - number of lines of data to be printed under the label
c      signns  - array containing sign associated with nonscanner record
c                level flags
c      line, m, j  - counters
c 
c   subroutines called -
c     none
c 
c   exit states - 
c     normal return 
c 
c   comments -
c 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
      character *1 signns( 10), cff
      character *32 label(36)
c 
      dimension xmwdt( 75,10) 
      dimension nline(36)
c
      data nline / 1,1,1,2,2,2,2,2,2,2,2,1,1,1,4,4,4,4,4,4,4,4,1,1,1,
     1             1,1,1,1,1,4,4,2,1,1,1 /
c
      cff = char(12)
c 
      do 100 l = 1, k 
c 
          signns( l) = ' '
c 
          if ( xmwdt( 71,l) .lt. 0.0) then
c 
             xmwdt( 71,l) = - xmwdt( 71, l) 
             signns( l) = '-' 
c 
          end if
c 
  100 continue
c 
c *** end do
c 
c 
c *** initialize counters for printing. 
c 
      j = 0 
      n = 0 
c 
c 
c     rewind (idatlbl)
c *** print out data, including labels. 
c 
      do 300 lbls = 1, 36 
c 
c        read(idatlbl,'(2i4,1x,a32,i4)', iostat = ios) index, istrln,
c    /   label, nline
c        if (ios.ne.0) then
c           iertyp = 2
c           call sysmsg(ios, iertyp, 'data')
c        end if
c 
c *** print out at top of new page if page is full. 
c 
       if (( lbls .eq. 1 ) .or. (( n + nline(lbls) + 2 ) .ge. 41 )) then
c 
CC        write(iunout,1000)
          write ( iunout,'(a1)')cff
          write(iunout,2000) iday 
          write(iunout,1020) ( irec - k + m, m = 1, k ) 
          write(iunout,*) 
          n = 5 
c 
         end if 
c 
c *** print out label 
c 
         if ( ( lbls .eq. 33 ) .or. ( lbls.eq. 34 ) ) then
c 
              write(iunout,1010) label(lbls)//' (octal)'
c 
         else 
c 
              write(iunout,1010) label(lbls)
c 
         end if 
c 
         n = n + 2
c 
c *** print out the records 
c 
         do 200 line = 1, nline(lbls)
c 
            j = j + 1 
c 
            if ( ( j .eq. 2 ) .or. ( j .eq. 3 ) ) then
c 
                 write ( iunout,1030) j, ( xmwdt( j, m), m = 1, k ) 
c 
            else if ( j .eq. 71 ) then
c 
                 write ( iunout, 1060) j, 
     1                 ( signns( m), int( xmwdt( j, m) ), m = 1, k) 
c 
            else if ( ( j .eq. 72 ) .or. ( j .eq. 73 ) ) then 
c 
                 write ( iunout, 1050) j, 
     1                 ( int( xmwdt( j, m) ) , m = 1, k)
c 
            else
c 
                 write ( iunout, 1040) j, ( xmwdt( j, m), m = 1, k )
c 
            end if
c 
  200    continue 
c 
c *** end do
c 
         n = n + nline(lbls)
c 
  300 continue
c 
c *** end do
c 
      return
c 
c *** format statements.
c 
 1000 format (1h1)
 1010 format( /, 1x, a )
 1020 format ( //1x, 13hrecord num = , 10x, i4, 9(8x, i4))
 1030 format ( 1x, 6hxmwdt(, i2, 4h) = , 4x, f11.7, 9( 1x,f11.7)) 
 1040 format ( 1x, 6hxmwdt(, i2, 4h) = , 4x, f11.2, 9( 1x, f11.2))
 1050 format ( 1x, 6hxmwdt(, i2, 4h) = , 4x, 1x, o10, 9( 2x, o10))
 1060 format ( 1x, 6hxmwdt(, i2, 4h) = , 4x, a1, o10, 9( 1x, a1, o10))
 2000 format ( /1x, 4hday:, i4 )
c 
      end 
c
       subroutine g16hedn(iounit,iobuf,idata,irc, s7nam)
c
c   **********************************************************
c 
c   name - g16hedn                            module -
c   language - ftn v                          type - subroutine 
c   version - 1.0         date - 12/18/92     programmer -
c                                               nolan, s.k. -lesc
c 
c   
c   purpose - to read physical header and create logical  
c             header information
c
c   input parameters  - 
c      iounit  - unit number of product containing physical header
c      irc     - record counter for external file containing product 
c      s7nam   - name of the s-7 file
c
c   output parameters  - 
c      iobuf  - logical header array
c      idata   - physical header array
c      irc     - record counter for external file containing product 
c
c   **********************************************************
c
       integer*2 idata(15)
       integer iobuf(9)
c *** read header
      read(iounit, iostat=ios,end=900,rec=irc) idata
      irc = irc + 30
c *** write product key
c     product key split into 2 parts: first 7 digits in iobuf(1)
c      nd last 7 digits in iobuf(9)
c   
       iobuf(1) = idata(1) * 10**6 + idata(2) * 10**4 +
     *            idata(3) * 10**3 + idata(4) 
       iobuf(9) = idata(5)  * 10**3 +
     *            (int((idata(6) )/ 1000)) * 10**2 +
     *            idata(7) 
       iobuf(2) = idata(3)
       iobuf(3) = idata(4) * 10**4 + idata(5)
       iobuf(4) = idata(6) * 10**5
       return
 900   call sysmsg(ios,2, s7nam)
       return
       end
c 
      subroutine julcal 
     i                (wholjd, fracjd, ind, 
     b
     o                 dat) 
c 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
c  name - julcal                                 module - g.e.8.5.2 
c  language - ftn v                              type - utility 
c  version - release 3.0     date - 08/03/82     programmer - zimmerman 
c 
c  purpose -
c     to convert a julian date to the corresponding calendar date 
c 
c  input parameters - 
c     wholjd : whole number part of the julian date (real)
c     fracjd : fractional part of the julian date (real decimal)
c        ind : control variable set to 0 to indicate input as julian date;
c              set to 1 to indicate input as number of days elapsed since 
c              0000 hours 01 january 1950 (integer) 
c 
c  output parameters -
c     dat : array of date elements as 2-digit real
c        dat(1)=yr
c        dat(2)=mo
c        dat(3)=da
c        dat(4)=hr
c        dat(5)=min 
c        dat(6)=sec     (with fractional part)
c 
c  key local parameters - 
c     intday : holds whole days since 0000 hr 01 january 1949 
c     fraday : holds portion of day since same
c     leapcy : number of four-year periods (1461 days)
c     morday : number of excess days after accounting for years 
c     iyr49  : number of years elapsed since 01 january 1949
c     moryr  : number of excess years after accounting for leapcy 
c     ymd    : yymm.dd and yy.mmdd
c     iyrmo  : yymm 
c     isec   : number of seconds in fractional part 
c 
c  subroutines called - 
c     local subroutine    - yymmdd (g.e.8.5.4)
c     intrinsic function  - int    (ftn v)
c     intrinsic function  - nint   (ftn v)
c     intrinsic function  - float   (ftn v) 
c     intrinsic function  - mod     (ftn v) 
c 
c  comments - 
c     the algorithm for this sub was provided by ed howerton.  the
c     nint function used in this sub is used to avoid truncation
c     errors in computations.  the general approach is to calculate 
c     days since 0000 hr on 01 january 1949.
c 
ccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc 
c 
c*****
      parameter ( ianal = 1 ) 
c 
c$    if ( ianal .eq. 1 ) then
         common /utlcnt/ ncalls(60) 
c$    endif 
c*****
      dimension dat(6)
c 
c$    if ( ianal .eq. 1 ) then
         ncalls( 23 ) = ncalls( 23 ) + 1
c$    endif 
c 
c *** the program does not combine whole and fractional parts, but
c *** works with each part separately.  this is done to maintain the
c *** maximum number of significant digits for each value.
c 
      if ( ind .eq. 0 ) then
         if ( fracjd .ge. 0.5 ) then
            intday = nint ( wholjd - 2432917. ) 
            fraday = fracjd - 0.5 
         else 
            fraday = fracjd + 0.5 
            intday = nint ( wholjd - 2432918. ) 
         end if 
      else
         intday = nint ( wholjd + 365. )
         fraday = fracjd
      end if
c 
      leapcy = intday / 1461
      morday = intday - ( leapcy * 1461 ) 
      iyr49  = leapcy * 4 
c 
c *** if the elapsed time is a multiple number of 4-year cycles with
c *** less than one year of additional time, these values are now 
c *** valid.  if a year or more remains in addition, however, the number
c *** of years must be accounted for.  because leap year is the fourth
c *** year of each 4-year cycle since 01 january 1949, each whole 
c *** elapsed year is 365 days in length. 
c 
      if ( morday .ge.365 ) then
         moryr  = morday / 365
         if (moryr .eq. 4) moryr = 3
         iyr49  = iyr49  + moryr
         morday = morday - ( moryr * 365 )
      end if
c 
      iyr  = iyr49 + 49 
      dat(1) = iyr
c 
c *** morday indicates how many additional days into the year must be 
c *** accounted for.  if it is the first day of the year, no additional 
c *** days need be accounted for, because 01 january is an exact number 
c *** of elapsed years.  on january 2, 1 more day must be accounted for.
c *** in general, to account for x more days, we need the x+1 day of
c *** the year. 
c 
      idayyr = morday + 1 
c 
c *** the function yymmdd will return the day of the year based on
c *** a number of days elapsed. 
c 
      call yymmdd 
     i          (iyr, idayyr, 
     b
     o           iymd)
c 
c *** from iymd, the month and day must be separated. 
c 
      dat(3) = float(mod(iymd,100)) 
      iyrmo  = iymd/100 
      dat(2) = float(mod(iyrmo,100))
c 
c *** the fractional part of the day will be converted into seconds by
c *** multiplying by total seconds per day (86400).  the excess will
c *** be truncated from seconds and captured into dat(6). 
c 
      isec   = int( 86400. * fraday ) 
      dat(6) = 86400. * fraday - float(isec)
      ihr    = isec / 3600
      dat(4) = float( ihr ) 
      isec   = isec - (ihr * 3600)
      imin   = isec / 60
      dat(5) = float( imin )
      dat(6) = float( isec - (imin *60 )) + dat(6)
c 
      return
      end 
c
      subroutine ppspec 
     i                ( iunout, ibuf, ipcn, prodcd, vsnfn) 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
c   name - ppspec                             module - g.5.20 
c   language - ftn v                          type - subroutine 
c   version - 3.6         date - 04/03/86     programmer -
c                                               johnson, m.j. - prc kentron 
c             3.8                10/05/88       johnson, m.j. - prc kentron 
c 
c 
c   purpose - 
c     to print out product specifications, including the temporal span, 
c     spacecraft name, product name, volume serial number or file name, 
c     and the associated erbe logical header. 
c 
c   input files - 
c     tape1 - global system constants 
c 
c   input parameters -
c     ibuf   - erbe logical header
c     ipcn   - product code 
c     iunout - unit number for printed product specifications 
c     prodcd - character string containing product name 
c     vsnfn  - volume serial number or file name of product 
c 
c   output files -
c     iunout - unit number for formatted print of product specifications
c 
c   output parameters - 
c     none
c 
c   key local parameters -
c     icraft - index into array of spacecraft names (iscnam)
c     iglob  - unit number for global system constants file 
c     ireslt - character string containing product temporal span
c     wjd    - whole part of the julian date
c     fjd    - fractional part of the julian date
c     /charcm/ - iscnam 
c     /global/ - isubno, iversn
c 
c   subroutines called -
c     datchr - routine used to create time span of a month based  
c              on julian date in character format 
c     sysmsg - handle system error message processing 
c 
c   exit states - 
c     normal return 
c 
c   restrictions -
c 
c   attributes -
c 
c   comments -
c 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
      character*6 iscnam(3)
c 
      character*30 ireslt 
      character*5  prodcd 
      character*7  vsnfn
c 
      data iscnam / 'NOAA 9', 'ERBS  ', 'NOAA10' /
      dimension ibuf( 9)
c 
c 
c 
c ***  verify product code, data date and spacecraft if 
c      a non-zero value is passed for ipcn
c 
      if ( ipcn .ne. 0 ) then 
c 
           isubno = 5 
c 
c 
      end if
c 
c ***  obtain temporal span **** 
c 
      wjd = float(ibuf(3))
      fjd = float(ibuf(4))/10.**9
      call datchr(wjd, fjd, ireslt)
c 
c ***  obtain spacecraft
c 
      icraft = ibuf( 2) 
c 
c ***  print out tape specifications
c 
      write ( iunout, 1000) 
      write ( iunout, 1010 ) ireslt 
      write ( iunout, 1020 ) iscnam( icraft)
      write ( iunout, 1030 ) prodcd 
      write ( iunout, 1040 ) vsnfn
c     i =1 
c     write ( iunout, 1050 )  i, ibuf( 1),ibuf(9) 
c     write ( iunout, 1060 ) ( i, ibuf( i), i = 2, 8) 
c 
c ***  format statements
c 
 1000 format (  // 1x, 23hproduct specifications: // )
 1010 format ( 5x, 18htemporal span  :  , a30 / ) 
 1020 format ( 5x, 18hspacecraft     :  , a6  / ) 
 1030 format ( 5x, 18hproduct        :  , a5  / ) 
 1040 format ( 5x, 18hvsn / file     :  , a7  / ) 
 1050 format ( 5x, 18hlogical header :  , 
     1         5hibuf(, i1, 4h) = , 2(i7)  )
 1060 format ( 7( 23x, 5hibuf(, i1, 4h) = , i15 /) )
c 
      return
      end 
c
      subroutine prphed 
     i                 (iunout, idata )
c 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
c   name - prphed                             module - g.5.21 
c   language - ftn v                          type - subroutine 
c   version - 3.6         date - 04/03/86     programmer -
c                                               johnson, m.j. - prc kentron 
c 
c 
c   purpose - 
c     to write an external output form physical header record
c 
c   input parameters - 
c     iunout - unit number for printed output 
c     idata  - array containing unpacked physical header information
c 
c   output files -
c     iunout - unit number for printed output 
c 
c   output parameters - 
c     none
c
c   subroutines called -
c     sysmsg - handles error message processing
c 
c   exit states - 
c     normal return 
c 
c   restrictions -
c 
c   attributes -
c 
c   comments -
c 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
c 
      integer*2  idata( 15) 
c 
c ***  print out contents of header 
c 
      write ( iunout, 1000) ( idata( i), i = 1, 13 )
c 
c *** format statements 
c 
 1000 format (/, 5x, 28hphysical header contents:    // 
     1           5x, 28hsubsystem indicator       : , i10 / 
     2           5x, 28hproduct code              : , i10 / 
     3           5x, 28hspacecraft indicator      : , i10 / 
     4           5x, 28hwhole julian date - high  : , i10 / 
     5           5x, 28hwhole julian date - low   : , i10 / 
     6           5x, 28hfractional julian date    : , i10 / 
     7           5x, 28hprocessed version counter : , i10 / 
     8           5x, 28hyear processed            : , i10 / 
     9           5x, 28hmonth processed           : , i10 / 
     a           5x, 28hday processed             : , i10 / 
     b           5x, 28hhour processed            : , i10 / 
     c           5x, 28hminute processed          : , i10 / 
     d           5x, 28hsecond processed          : , i10 /// ) 
c 
      return
c 
      end 
c
c 
      subroutine sfoff
     i                ( k ) 
c 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
c   name - sfoff                              module -
c   language - ftn v                          type - subroutine 
c   version - 3.0         date - 07/26/89     programmer -
c                                               flug, b.t. - prc
c 
c 
c   purpose - 
c     to apply scale factors and offsets to monthly medium-wide data
c 
c   input parameters -
c      k - counts number of records being dumped
c 
c   output parameters - 
c      xmwdt - array(10) containing up to 10 unpacked s-7 records 
c 
c   key local parameters -
c      istart - starting location in monthly medium-wide data array 
c               for 32 or 16 bit words
c      istop  - number of 32 or 16 bit words in the monthly 
c               medium-wide data array
c      /scldat/  - ierror, nfwa, mnwd, xerror, xmwdt, xmwoff, xmwsf
c 
c   subroutines called -
c     none
c 
c   exit states - 
c     normal return 
c 
c   comments -
c 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
      common / scldat / ierror(2),  mfwa(4), mnwd(4), 
     1                  iumwd(75),  xerror,  xmwdt(75,10),
     2                  xmwoff(75), xmwsf(75) 
c 
c *** apply scale factors and offsets 
c 
      do 200 i = 1, 2 
c 
         istart = mfwa( i)
         istop = mfwa( i) + mnwd( i) - 1
c 
         do 100 j = istart, istop 
c 
            if( iumwd( j) .eq. ierror( i) ) then
c 
c           *** data element contains default value 
c 
                xmwdt( j,k) = xerror
c 
            else
c 
c           *** data element contains real data 
c 
                xmwdt( j,k) = float( iumwd( j) )/xmwsf( j) - xmwoff( j) 
c 
            end if
c 
  100    continue 
c 
  200 continue
c 
      return
c 
      end 
c
      subroutine sysmsg ( i, j, filename )
c 
c 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
c   name - sysmsg                             module -
c   language - ftn v                          type - subroutine 
c   version -             date - 87/01/13     programmer -
c                                               johnson, m.j. - prc kentron 
c 
c 
c   purpose - to write error messages to an error message file. 
c 
c   input files - 
c       none
c 
c   input parameters -
c       i      - error number
c       j      - error classification code; a code of 1 
c                indicates an error in opening a file; a code of 2 indicates
c                an error in reading from the file 
c     filename - name of file where I/O error trapped
c
c   output files -
c       tape16 - error message file 
c 
c   output parameters - 
c         none
c 
c   subroutines called -
c         none
c 
c   exit states - 
c         none 
c 
c   restrictions -
c 
c   attributes -
c 
c   comments -
c 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
c 
       character * 8 filename
       if (j.eq.1) then
	  write(16, 10) i, filename
10	  format(1x, 'I/O error number', i4, 'occurred while opening
     /the file ', a8)
	else if (j.eq.2) then
	  write(16, 20) i, filename
20	  format(1x, 'I/O error number', i4, 'occurred while reading
     /from the file ', a8)
	endif
c
	stop
	end
c
      subroutine yymmdd 
     i                (iyr, iday, 
     b
     o                 iyymmd)
c 
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
c 
c  name - yymmdd                                 module - g.e.8.5.4 
c  language - ftn v                              type - subroutine
c  version - 3.0             date - 08/03/82     programmer - tolson
c                                                          zimmerman
c 
c  purpose -
c     change from number of day of the year to a date 
c 
c  input parameters - 
c     iyr  : 2-digit year (integer) 
c     iday : 3-digit day (001-366) (integer)
c 
c  output parameters -
c     iyymmd : yymmdd (6-digit integer) 
c              (year*10000 + month*100 + day) 
c 
c  key local parameters - 
c     jday   : number of days into the year 
c     leap   : leap year indicator (0=leap year)
c     idymon : array of days elapsed as of the start of each month. 
c                first dimension is 1 for regular year, 2 for leap year.
c     irow   : first (leap year) dimensioning indicator for idymon
c     imon1  : second (month) dimensioning indicator for idymon 
c 
c  subroutines called - 
c     none
c  comments - 
c     this sub will not consider leap centuries 
c 
ccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc 
c 
c 
c*****
      parameter ( ianal = 1 ) 
c 
c$    if ( ianal .eq. 1 ) then
         common /utlcnt/ ncalls(60) 
c$    endif 
c*****
      dimension idymon(2,13)
c 
      data (idymon(1,k), k=1, 13) 
     2   /0,31,59,90,120,151,181,212,243,273,304,334,365/ 
      data (idymon(2,k), k=1, 13) 
     2   /0,31,60,91,121,152,182,213,244,274,305,335,366/ 
c 
c$    if ( ianal .eq. 1 ) then
         ncalls( 54 ) = ncalls( 54 ) + 1
c$    endif 
c 
      jday   = iday 
      leap   = iyr - ( iyr/4 )*4
c 
      if ( leap .eq. 0 ) then 
         irow = 2 
      else
         irow = 1 
      end if
c 
c *** locate the proper month of the year by stepping backwards 
c *** and checking total days elapsed.
c 
      imon1 = 13
c 
c *** do until (idymon .lt. jday) 
c 
 1380 imon1 = imon1 - 1 
      if ( .not. ( idymon(irow,imon1) .lt. jday ) ) goto 1380 
c 
c *** end do
c 
      jday = jday - idymon(irow,imon1)
      iyymmd = ( iyr*10000 ) + ( imon1*100 ) + jday 
c 
      return
      end 
